{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node10",
    "lib": ["ES2020", "DOM"],
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": ["src/types", "node_modules/@types"],
    "strict": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}
